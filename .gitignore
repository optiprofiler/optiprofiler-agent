# Secrets (never commit real keys).
# `.env.*` catches per-environment overrides like `.env.local`, `.env.staging`.
# Two intentional exceptions:
#   - `.env.example`            — the project-local override template at repo root
#   - `.env.template` under     — the bundled seed copied into ~/.opagent/.env on
#     `runtime/_seed/`            first run; SHIPS in the wheel via package-data,
#                                 so it must also exist in the source tree (and
#                                 therefore in git) or CI / fresh clones break.
.env
.env.*
!.env.example
!optiprofiler_agent/runtime/_seed/.env.template

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg
dist/
build/
wheels/
*.whl
pip-log.txt

# Virtual environments
.venv/
venv/
ENV/

# Tool caches
.ruff_cache/
.pytest_cache/
.mypy_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~
.idea/
*.sublime-*

# Local benchmark / scratch (entire folder — not part of the published package)
op_test/

# Chroma / local RAG persistence
*.chroma/
.chroma_db/

# Local eval harness outputs (may include upstream API error payloads)
results.json
report.md

# Agent runtime data (OPAGENT_HOME). Default is ~/.opagent/ (outside repo),
# but devs sometimes set OPAGENT_HOME=./.opagent for sandboxed testing —
# never commit any of that back into the package source tree.
.opagent/
.opagent_test/
**/.bootstrapped.json
**/sessions.db
**/sessions.db-*
optiprofiler_agent/runtime/wiki/auto/
trajectories/
