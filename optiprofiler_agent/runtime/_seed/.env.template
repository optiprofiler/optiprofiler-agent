# ============================================================================
# OptiProfiler Agent — user-level secrets file (seed template).
#
# This template is copied to ~/.opagent/.env on first run. After that it is
# NEVER overwritten by `pip install --upgrade`, so any keys you fill in
# here survive package upgrades.
#
# Recommended workflow: run `opagent init` and let the wizard write this
# file for you. Hand-editing also works — just uncomment the line for the
# provider you intend to use, paste your key, and save.
#
# Precedence (highest first):
#   1. Real shell env (`export FOO=...`)
#   2. ./.env in your current working directory (project-local)
#   3. THIS FILE (~/.opagent/.env, user-level)
# So `export` and a project-local `.env` always beat values set here.
#
# After saving, optionally restrict file permissions:
#     chmod 600 ~/.opagent/.env
# ============================================================================

# Default provider used when no --provider flag is passed.
# Allowed: minimax | kimi | openai | deepseek | anthropic | custom
# OPAGENT_DEFAULT_PROVIDER=minimax

# --- Built-in providers (uncomment ONE) -------------------------------------
# MINIMAX_API_KEY=your-minimax-key-here
# KIMI_API_KEY=sk-your-kimi-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here   # requires `pip install 'optiprofiler-agent[anthropic]'`

# --- Optional: pin a specific model / route through a proxy ----------------
# Built-in providers ship with sensible model defaults (see
# `PROVIDER_REGISTRY` in config.py), but model names change ("kimi-k2" →
# "kimi-k2-thinking") and corp networks often need a proxy. Set either
# variable to override **without** switching to provider=custom.
#
# Precedence: --model CLI flag > OPAGENT_DEFAULT_MODEL > registry default.
# OPAGENT_DEFAULT_MODEL=kimi-k2-thinking
# OPAGENT_DEFAULT_BASE_URL=https://my-corp-proxy.example.com/v1

# --- Custom OpenAI-compatible endpoint (any unlisted vendor / self-hosted) --
# Set OPAGENT_DEFAULT_PROVIDER=custom above, then fill all three:
# OPAGENT_CUSTOM_BASE_URL=https://api.example.com/v1
# OPAGENT_CUSTOM_MODEL=your-model-name
# OPAGENT_CUSTOM_API_KEY=sk-your-key-here

# --- Optional: web_search tool (Tavily) ------------------------------------
# Required only if you `pip install 'optiprofiler-agent[web]'` and want the
# unified agent's web_search tool to actually hit the network.
# TAVILY_API_KEY=tvly-your-tavily-key-here
