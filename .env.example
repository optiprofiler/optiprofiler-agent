# OptiProfiler Agent — LLM API Keys
# Copy this file to .env and fill in your key(s).
# You only need ONE provider configured.
#
# CLI: use `opagent` (recommended) or `optiprofiler-agent` — same commands after pip install.

# Kimi (Moonshot AI)
KIMI_API_KEY=sk-your-kimi-key-here

# MiniMax
MINIMAX_API_KEY=your-minimax-key-here

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek (optional)
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Anthropic (optional, requires: pip install 'optiprofiler-agent[anthropic]')
# ANTHROPIC_API_KEY=sk-ant-your-key-here
